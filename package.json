    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.9",
    "next": "14.2.35",
    "prisma": "^6.19.3",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
