# ─── Required ───────────────────────────────────────────────────────────
# Local dev  : SQLite file   e.g. file:./dev.db
# Production : Postgres URL  e.g. postgres://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require
DATABASE_URL="file:./dev.db"

# Used to sign JWT cookies (tutor sessions + per-attempt tokens).
# Production: generate a 32+ char random string and keep it secret.
JWT_SECRET="dev-only-change-me-to-a-long-random-string-for-production-use-please"

# ─── Optional ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Language Proficiency Assessment"
